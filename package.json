{
  "name": "unibee-automation",
  "version": "1.0.0",
  "description": "Automation test framework for Unibee based on JavaScript, Mocha, Selenium and Axios.",
  "main": "index.js",
  "scripts": {
    "test": "npm run test:all",
    "test:all": "npm run test:web && npm run test:api",
    "test:web": "mocha --timeout 60000 --recursive \"Web/TestCases/**/*.spec.js\"",
    "test:api": "mocha --timeout 30000 --recursive \"API/TestCases/**/*.spec.js\""
  },
  "keywords": [
    "unibee",
    "automation",
    "mocha",
    "selenium",
    "axios"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.13.1",
    "selenium-webdriver": "^4.37.0"
  },
  "devDependencies": {
    "mocha": "^11.7.4"
  }
}
